[Unit]
Description=Flac Guard RTSP-to-RTMP Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/opt/flac-guard/rtsp-to-rtmp.sh /etc/flac-guard-agent.conf
Restart=always
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
