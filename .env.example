# Flac Guard — Environment Variables

# JWT secret for dashboard authentication
JWT_SECRET=change-me-to-a-random-secret-key

# Database (used by docker-compose)
POSTGRES_USER=flac_guard
POSTGRES_PASSWORD=flac_guard
POSTGRES_DB=flac_guard

# HappyDo Pulse integration (for PDV sync)
PULSE_API_URL=https://happydopulse-production.up.railway.app/api
PULSE_EMAIL=
PULSE_PASSWORD=

# Deploy webhook secret (auto-generated by setup.sh)
WEBHOOK_SECRET=
